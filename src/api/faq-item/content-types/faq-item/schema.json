{
  "kind": "collectionType",
  "collectionName": "faq_items",
  "info": {
    "singularName": "faq-item",
    "pluralName": "faq-items",
    "displayName": "FAQ Item",
    "description": "Questions fréquentes thématiques affichées sur la page d'accueil et la page FAQ"
  },
  "options": { "draftAndPublish": true },
  "pluginOptions": {},
  "attributes": {
    "question": { "type": "string", "required": true },
    "reponse": { "type": "blocks", "required": true },
    "theme": {
      "type": "enumeration",
      "enum": ["eligibilite", "dossier", "financement", "selection"],
      "required": true
    },
    "ordre": { "type": "integer", "required": true },
    "publie": { "type": "boolean", "default": true }
  }
}
