{
  "kind": "collectionType",
  "collectionName": "conditions_prealables",
  "info": {
    "singularName": "condition-prealable",
    "pluralName": "conditions-prealables",
    "displayName": "Condition prealable"
  },
  "options": { "draftAndPublish": false },
  "pluginOptions": {},
  "attributes": {
    "subvention": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::subvention.subvention",
      "inversedBy": "conditionsPrealables"
    },
    "libelle": { "type": "string", "required": true },
    "statut": {
      "type": "enumeration",
      "enum": ["validee", "en_cours_ugp", "action_requise"],
      "default": "en_cours_ugp"
    },
    "echeance": { "type": "date" },
    "fichierDepose": { "type": "media", "multiple": false, "allowedTypes": ["files", "images"] },
    "dateValidation": { "type": "date" },
    "ordre": { "type": "integer", "default": 0 },
    "technique": { "type": "boolean", "default": false },
    "avisTechnique": { "type": "enumeration", "enum": ["favorable", "reserve", "defavorable"] },
    "avisTechniqueCommentaire": { "type": "text" },
    "avisTechniquePar": { "type": "relation", "relation": "manyToOne", "target": "plugin::users-permissions.user" },
    "valideePar": { "type": "relation", "relation": "manyToOne", "target": "plugin::users-permissions.user" },
    "valideeLe": { "type": "datetime" }
  }
}
