{
  "kind": "collectionType",
  "collectionName": "resource_documents",
  "info": {
    "singularName": "resource-document",
    "pluralName": "resource-documents",
    "displayName": "Resource Document"
  },
  "options": { "draftAndPublish": true },
  "pluginOptions": {},
  "attributes": {
    "title": { "type": "string", "required": true },
    "category": {
      "type": "enumeration",
      "enum": ["appel", "tdr", "formulaire", "modele", "guide", "grille", "manuel", "note", "rapport", "autre"],
      "default": "autre"
    },
    "description": { "type": "text" },
    "file": { "type": "media", "multiple": false, "allowedTypes": ["files"], "required": true }
  }
}
