{
  "kind": "collectionType",
  "collectionName": "value_chains",
  "info": {
    "singularName": "value-chain",
    "pluralName": "value-chains",
    "displayName": "Value Chain"
  },
  "options": { "draftAndPublish": true },
  "pluginOptions": {},
  "attributes": {
