HOST=0.0.0.0
PORT=1337
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# Frontend origins allowed to call the CMS API.
# Replace the Render URL with the DigitalOcean App Platform portal URL in production.
CORS_ORIGINS="https://prete-suco-portal.onrender.com,http://localhost:3000"

# DigitalOcean Spaces media storage.
# Leave these unset locally to keep Strapi's default local upload provider.
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_BUCKET=
DO_SPACES_REGION=fra1
DO_SPACES_ENDPOINT=https://fra1.digitaloceanspaces.com
DO_SPACES_BASE_URL=https://your-bucket.fra1.digitaloceanspaces.com
DO_SPACES_CDN_URL=
DO_SPACES_ROOT_PATH=uploads
DO_SPACES_ACL=public-read
DO_SPACES_FORCE_PATH_STYLE=false

# URLs used in notification emails.
PORTAL_BASE_URL=http://localhost:3000
PUBLIC_CMS_URL=http://localhost:1337

# SMTP used to send "Être notifié" emails when an AMI opens.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
NOTIFICATION_FROM_EMAIL=
NOTIFICATION_FROM_NAME="SUBCO PRETE"
AMI_NOTIFICATION_CRON=*/10 * * * *
